{
  "name": "pi-zenmux-provider",
  "version": "2.2.0",
  "description": "Pi extension that registers ZenMux AI as an OpenAI-compatible model provider.",
  "license": "MIT",
  "author": "KelpHect",
  "homepage": "https://github.com/KelpHect/pi-zenmux-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KelpHect/pi-zenmux-provider.git"
  },
  "bugs": {
    "url": "https://github.com/KelpHect/pi-zenmux-provider/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "zenmux",
    "zenmux-ai",
    "llm",
    "openai-compatible",
    "ai-provider",
    "coding-agent"
  ],
  "type": "module",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "tsx --test --test-concurrency=1 tests/unit/*.test.ts",
    "test:watch": "tsx --test --watch --test-concurrency=1 tests/unit/*.test.ts",
    "test:live": "tsx --test --test-concurrency=1 tests/live/zenmux.live.ts",
    "pack:check": "node scripts/package-check.mjs",
    "smoke:pack": "node scripts/packed-install-smoke.mjs",
    "catalog:refresh": "tsx scripts/refresh-fallback-models.ts",
    "verify": "npm run check && npm test && npm run pack:check && npm run smoke:pack",
    "prepublishOnly": "npm run verify"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.7",
    "@earendil-works/pi-coding-agent": ">=0.80.7"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@types/node": "^22.19.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
